FROM debian:bookworm-slim
# Mirror the prod runtime image (Dockerfile @ FROM debian:bookworm-slim
# stage) — same OS, same shell tools — so bash scripts behave identically
# in dev. We don't bother building freeciv-server itself; nothing we test
# requires a running server (the wrappers we care about take a save file
# as input and produce JSON output).

RUN apt-get update && apt-get install -y --no-install-recommends \
    bash \
    curl \
    ca-certificates \
    coreutils \
    gzip \
    jq \
    sqlite3 \
    libsqlite3-0 \
    busybox-static \
    python3 python3-pip python3-venv \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY pyproject.toml ./
COPY lib ./lib
COPY bin ./bin
COPY tests ./tests

RUN python3 -m venv /opt/venv && \
    /opt/venv/bin/pip install -e ".[dev]"

ENV PATH="/opt/venv/bin:$PATH"

CMD ["pytest", "-v"]
