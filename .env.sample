# OpenAI API key (optional, for AI-generated gazette)
OPENAI_API_KEY=  # sk-proj-abc123...

# AWS SES SMTP credentials (required for email notifications)
SES_SMTP_USER=  # AKIA3EXAMPLE
SES_SMTP_PASS=  # BCD1234exampleSecretKey
SES_SMTP_HOST=email-smtp.us-east-1.amazonaws.com

# Email settings
CC_EMAIL=  # admin@example.com
FROM_EMAIL=  # freeciv@example.com

# Server hostname (used in emails and status page)
SERVER_HOST=  # freeciv.example.com
